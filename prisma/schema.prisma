generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  engineType      = "library"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [postgis, uuid_ossp(map: "uuid-ossp"), pg_trgm]
}

model User {
  id                 String        @id @default(cuid())
  auth0Id            String        @unique
  email              String        @unique
  name               String?
  role               UserRole
  stripeCustomerId   String?       @unique
  isPaid             Boolean       @default(false)
  subscriptionTier   String?
  createdAt          DateTime      @default(now())
  subscriptionStatus String?
  bandProfile        Band?
  bandMemberships    BandMember[]
  venueProfile       Venue?
  venueMemberships   VenueMember[]
  artistMedia        ArtistMedia[]
}

model ArtistMedia {
  id        String   @id @default(cuid())
  artistId  String   @map("artist_id")
  fileUrl   String   @map("file_url")
  fileType  String   @map("file_type") // 'image' or 'audio'
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@map("artist_media")
}

model Band {
  id               String                    @id @default(cuid())
  userId           String                    @unique
  name             String
  lat              Float?
  lng              Float?
  location         Unsupported("geography")?
  city             String?
  searchRadius     Int                       @default(50)
  audioUrlPreview  String?
  audioUrlFull     String?
  taxStatus        Boolean                   @default(false)
  bio              String?
  media            Json?
  negotiationPrefs Json?
  socialLinks      Json?                     @default("{\"instagram\": \"\", \"twitter\": \"\", \"spotify\": \"\", \"website\": \"\"}")
  user             User                      @relation(fields: [userId], references: [id])
  members          BandMember[]
  gigs             Gig[]
  availabilities   Availability[]
  genres           Genre[]                   @relation("BandGenres")

  @@index([location], type: Gist)
}

model Venue {
  id               String                    @id @default(cuid())
  userId           String                    @unique
  name             String
  lat              Float?
  lng              Float?
  location         Unsupported("geography")?
  city             String?
  capacity         Int?
  bio              String?
  media            Json?
  negotiationPrefs Json?
  socialLinks      Json?                     @default("{\"instagram\": \"\", \"twitter\": \"\", \"spotify\": \"\", \"website\": \"\"}")
  gigs             Gig[]
  user             User                      @relation(fields: [userId], references: [id])
  members          VenueMember[]
  availabilities   Availability[]
  genres           Genre[]                   @relation("VenueGenres")

  @@index([location], type: Gist)
}

model Genre {
  id     String  @id @default(cuid())
  name   String  @unique
  bands  Band[]  @relation("BandGenres")
  venues Venue[] @relation("VenueGenres")
}

model BandMember {
  id        String     @id @default(cuid())
  bandId    String
  userId    String
  role      MemberRole @default(MEMBER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  band      Band       @relation(fields: [bandId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bandId, userId])
}

model VenueMember {
  id        String     @id @default(cuid())
  venueId   String
  userId    String
  role      MemberRole @default(MEMBER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue     Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, userId])
}

model Availability {
  id          String             @id @default(cuid())
  bandId      String?
  venueId     String?
  eventDate   DateTime
  status      AvailabilityStatus @default(AVAILABLE)
  description String?
  createdAt   DateTime           @default(now())
  band        Band?              @relation(fields: [bandId], references: [id], onDelete: Cascade)
  venue       Venue?             @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([eventDate])
}

model Gig {
  id                    String            @id @default(cuid())
  contractUrl           String?
  bandId                String
  venueId               String
  createdAt             DateTime          @default(now())
  date                  DateTime
  description           String?
  platformFee           Float             @default(0)
  title                 String
  totalAmount           Float
  updatedAt             DateTime          @updatedAt
  status                GigStatus         @default(DRAFT)
  engagementType        EngagementType    @default(REQUEST)
  depositPaid           Boolean           @default(false)
  holdExpiresAt         DateTime?
  stripePaymentIntentId String?           @unique
  payoutStatus          PayoutStatus      @default(NOT_APPLICABLE)
  agreement             BookingAgreement?
  band                  Band              @relation(fields: [bandId], references: [id])
  venue                 Venue             @relation(fields: [venueId], references: [id])
  offers                Offer[]
  offerHistory          OfferHistory[]
}

model BookingAgreement {
  id                String     @id @default(cuid())
  gigId             String     @unique
  payoutType        PayoutType @default(CASH_DOS)
  dealStructure     DealType   @default(GUARANTEE)
  amount            Float
  loadInTime        String
  soundCheckTime    String
  setStartTime      String
  setDuration       Int
  venueAccepted     Boolean    @default(false)
  bandAccepted      Boolean    @default(false)
  contractSigned    Boolean    @default(false)
  stagePlotSnapshot String?
  i9Snapshot        String?
  gig               Gig        @relation(fields: [gigId], references: [id])
}

model Offer {
  id          String   @id @default(cuid())
  gigId       String
  amount      Float
  message     String?
  createdById String
  createdAt   DateTime @default(now())
  gig         Gig      @relation(fields: [gigId], references: [id])
}

model OfferHistory {
  id           String    @id @default(cuid())
  gigId        String
  fromStatus   GigStatus
  toStatus     GigStatus
  changedById  String
  changeReason String?
  createdAt    DateTime  @default(now())
  gig          Gig       @relation(fields: [gigId], references: [id])

  @@index([gigId, createdAt])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

enum MemberRole {
  OWNER
  MANAGER
  MEMBER
  GUEST
}

enum GigStatus {
  DRAFT
  SUBMISSION
  REQUEST
  PENDING_APPROVAL
  OFFER_SENT
  COUNTER_OFFER
  ACCEPTED
  REJECTED
  BOOKED
  COMPLETED
  CANCELLED
  ESCROW_HOLD
  CONFIRMED
}

enum AvailabilityStatus {
  AVAILABLE
  BOOKED
  PAST
  CONFIRMED
}

enum EngagementType {
  SUBMISSION
  REQUEST
}

enum UserRole {
  BAND
  VENUE
}

enum PayoutType {
  FABT_PAY
  CASH_DOS
}

enum DealType {
  GUARANTEE
  SPLIT
  NEGOTIABLE
}

enum PayoutStatus {
  NOT_APPLICABLE
  HELD_IN_ESCROW
  RELEASED_TO_BAND
  REFUNDED_TO_VENUE
}
