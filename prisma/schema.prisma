generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  engineType      = "library"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [postgis, uuid_ossp(map: "uuid-ossp")]
}

model User {
  id                 String        @id @default(cuid())
  auth0Id            String        @unique
  email              String        @unique
  role               UserRole
  stripeCustomerId   String?       @unique
  isPaid             Boolean       @default(false)
  subscriptionTier   String?
  createdAt          DateTime      @default(now())
  subscriptionStatus String?
  bandProfile        Band?
  bandMemberships    BandMember[]
  venueProfile       Venue?
  venueMemberships   VenueMember[]
}

model Band {
  id               String                    @id @default(cuid())
  userId           String                    @unique
  name             String
  lat              Float?
  lng              Float?
  location         Unsupported("geography")?
  searchRadius     Int                       @default(50)
  audioUrlPreview  String?
  audioUrlFull     String?
  taxStatus        Boolean                   @default(false)
  availability     Json?
  bio              String?
  media            Json?
  negotiationPrefs Json?
  user             User                      @relation(fields: [userId], references: [id])
  members          BandMember[]
  gigs             Gig[]

  @@index([location], type: Gist)
}

model Venue {
  id               String                    @id @default(cuid())
  userId           String                    @unique
  name             String
  lat              Float?
  lng              Float?
  location         Unsupported("geography")?
  capacity         Int?
  availability     Json?
  bio              String?
  media            Json?
  negotiationPrefs Json?
  gigs             Gig[]
  user             User                      @relation(fields: [userId], references: [id])
  members          VenueMember[]

  @@index([location], type: Gist)
}

model BandMember {
  id        String     @id @default(cuid())
  bandId    String
  userId    String
  role      MemberRole @default(MEMBER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  band      Band       @relation(fields: [bandId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bandId, userId])
}

model VenueMember {
  id        String     @id @default(cuid())
  venueId   String
  userId    String
  role      MemberRole @default(MEMBER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue     Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, userId])
}

model Gig {
  id                    String            @id @default(cuid())
  contractUrl           String?
  bandId                String
  venueId               String
  createdAt             DateTime          @default(now())
  date                  DateTime
  description           String?
  platformFee           Float             @default(0)
  title                 String
  totalAmount           Float
  updatedAt             DateTime          @updatedAt
  status                GigStatus         @default(DRAFT)
  depositPaid           Boolean           @default(false)
  holdExpiresAt         DateTime?
  stripePaymentIntentId String?           @unique
  payoutStatus          PayoutStatus      @default(NOT_APPLICABLE)
  agreement             BookingAgreement?
  band                  Band              @relation(fields: [bandId], references: [id])
  venue                 Venue             @relation(fields: [venueId], references: [id])
  offers                Offer[]
  history               OfferHistory[]
}

model BookingAgreement {
  id                String     @id @default(cuid())
  gigId             String     @unique
  payoutType        PayoutType @default(CASH_DOS)
  dealStructure     DealType   @default(GUARANTEE)
  amount            Float
  loadInTime        String
  soundCheckTime    String
  setStartTime      String
  setDuration       Int
  venueAccepted     Boolean    @default(false)
  bandAccepted      Boolean    @default(false)
  contractSigned    Boolean    @default(false)
  stagePlotSnapshot String?
  i9Snapshot        String?
  gig               Gig        @relation(fields: [gigId], references: [id])
}

model Offer {
  id          String   @id @default(cuid())
  gigId       String
  amount      Float
  message     String?
  createdById String
  createdAt   DateTime @default(now())
  gig         Gig      @relation(fields: [gigId], references: [id])
}

model OfferHistory {
  id           String    @id @default(cuid())
  gigId        String
  fromStatus   GigStatus
  toStatus     GigStatus
  changedById  String
  changeReason String?
  timestamp    DateTime  @default(now())
  gig          Gig       @relation(fields: [gigId], references: [id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

enum MemberRole {
  OWNER
  MANAGER
  MEMBER
  GUEST
}

enum GigStatus {
  DRAFT
  OFFER_SENT
  COUNTER_OFFER
  ACCEPTED
  REJECTED
  BOOKED
  COMPLETED
  CANCELLED
  ESCROW_HOLD
  CONFIRMED
}

enum UserRole {
  BAND
  VENUE
}

enum PayoutType {
  FABT_PAY
  CASH_DOS
}

enum DealType {
  GUARANTEE
  SPLIT
  NEGOTIABLE
}

enum PayoutStatus {
  NOT_APPLICABLE
  HELD_IN_ESCROW
  RELEASED_TO_BAND
  REFUNDED_TO_VENUE
}
