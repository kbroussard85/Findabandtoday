generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  engineType      = "library"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pg_trgm, postgis, uuid_ossp(map: "uuid-ossp")]
}

model User {
  id                 String        @id @default(cuid())
  auth0Id            String        @unique
  email              String        @unique
  role               UserRole
  stripeCustomerId   String?       @unique
  isPaid             Boolean       @default(false)
  subscriptionTier   String?
  createdAt          DateTime      @default(now())
  subscriptionStatus String?
  name               String?
  stripeAccountId    String?       @unique
  bandProfile        Band?
  bandMemberships    BandMember[]
  venueProfile       Venue?
  venueMemberships   VenueMember[]
  artistMedia        ArtistMedia[]
  vaultAssets        VaultAsset[]
}

model ArtistMedia {
  id        String   @id @default(cuid())
  artistId  String   @map("artist_id")
  fileUrl   String   @map("file_url")
  fileType  String   @map("file_type")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@map("artist_media")
}

model Band {
  id               String                    @id @default(cuid())
  userId           String                    @unique
  name             String
  lat              Float?
  lng              Float?
  location         Unsupported("geography")?
  searchRadius     Int                       @default(50)
  audioUrlPreview  String?
  audioUrlFull     String?
  taxStatus        Boolean                   @default(false)
  bio              String?
  media            Json?
  negotiationPrefs Json?
  minPayoutRequirement Float @default(0)
  vaultCompleted   Boolean @default(false)
  logoUrl          String?
  socialLinks      Json?                     @default("{\"spotify\": \"\", \"youtube\": \"\", \"tiktok\": \"\", \"instagram\": \"\", \"website\": \"\"}")
  city             String?
  availabilities   Availability[]
  user             User                      @relation(fields: [userId], references: [id])
  members          BandMember[]
  gigs             Gig[]
  ratings          Rating[]
  genres           Genre[]                   @relation("BandGenres")

  @@index([location], type: Gist)
}

model Venue {
  id               String                    @id @default(cuid())
  userId           String                    @unique
  name             String
  lat              Float?
  lng              Float?
  location         Unsupported("geography")?
  capacity         Int?
  bio              String?
  media            Json?
  negotiationPrefs Json?
  minPayoutRequirement Float @default(0)
  vaultCompleted   Boolean @default(false)
  logoUrl          String?
  socialLinks      Json?                     @default("{\"spotify\": \"\", \"youtube\": \"\", \"tiktok\": \"\", \"instagram\": \"\", \"website\": \"\"}")
  city             String?
  availabilities   Availability[]
  gigs             Gig[]
  openDates        OpenDate[]
  givenRatings     Rating[]
  user             User                      @relation(fields: [userId], references: [id])
  agreements       VenueAgreement[]
  members          VenueMember[]
  genres           Genre[]                   @relation("VenueGenres")

  @@index([location], type: Gist)
}

model Rating {
  id        String   @id @default(cuid())
  bandId    String
  venueId   String
  stars     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  band      Band     @relation(fields: [bandId], references: [id], onDelete: Cascade)
  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([bandId, venueId])
  @@index([bandId])
}

model Genre {
  id     String  @id @default(cuid())
  name   String  @unique
  bands  Band[]  @relation("BandGenres")
  venues Venue[] @relation("VenueGenres")
}

model BandMember {
  id        String     @id @default(cuid())
  bandId    String
  userId    String
  role      MemberRole @default(MEMBER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  band      Band       @relation(fields: [bandId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bandId, userId])
}

model VenueMember {
  id        String     @id @default(cuid())
  venueId   String
  userId    String
  role      MemberRole @default(MEMBER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue     Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, userId])
}

model Availability {
  id          String             @id @default(cuid())
  bandId      String?
  venueId     String?
  eventDate   DateTime
  status      AvailabilityStatus @default(AVAILABLE)
  description String?
  createdAt   DateTime           @default(now())
  band        Band?              @relation(fields: [bandId], references: [id], onDelete: Cascade)
  venue       Venue?             @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([eventDate])
}

model Gig {
  id                    String            @id @default(cuid())
  contractUrl           String?
  bandId                String
  venueId               String
  createdAt             DateTime          @default(now())
  date                  DateTime
  depositPaid           Boolean           @default(false)
  description           String?
  expiresAt             DateTime?         @default(dbgenerated("(now() + '72:00:00'::interval)"))
  holdExpiresAt         DateTime?
  isActive              Boolean           @default(true)
  payoutStatus          PayoutStatus      @default(NOT_APPLICABLE)
  platformFee           Float             @default(0)
  stripePaymentIntentId String?           @unique
  title                 String
  totalAmount           Float
  updatedAt             DateTime          @updatedAt
  status                GigStatus         @default(DRAFT)
  engagementType        EngagementType    @default(REQUEST)
  paymentMethod         PaymentMethod?
  totalGuarantee        Float?
  agreement             BookingAgreement?
  band                  Band              @relation(fields: [bandId], references: [id])
  venue                 Venue             @relation(fields: [venueId], references: [id])
  offers                Offer[]
  offerHistory          OfferHistory[]
}

model BookingAgreement {
  id                String     @id @default(cuid())
  gigId             String     @unique
  payoutType        PayoutType @default(CASH_DOS)
  dealStructure     DealType   @default(GUARANTEE)
  amount            Float
  loadInTime        String
  soundCheckTime    String
  setStartTime      String
  setDuration       Int
  venueAccepted     Boolean    @default(false)
  bandAccepted      Boolean    @default(false)
  contractSigned    Boolean    @default(false)
  stagePlotSnapshot String?
  i9Snapshot        String?
  gig               Gig        @relation(fields: [gigId], references: [id])
}

model Offer {
  id          String   @id @default(cuid())
  gigId       String
  amount      Float
  message     String?
  createdById String
  createdAt   DateTime @default(now())
  gig         Gig      @relation(fields: [gigId], references: [id])
}

model OfferHistory {
  id           String    @id @default(cuid())
  gigId        String
  fromStatus   GigStatus
  toStatus     GigStatus
  changedById  String
  changeReason String?
  createdAt    DateTime  @default(now())
  gig          Gig       @relation(fields: [gigId], references: [id])

  @@index([gigId, createdAt])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model engagements {
  id                                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sender_id                                  String?
  receiver_id                                String?
  type                                       String?
  status                                     String?   @default("pending")
  event_date                                 DateTime? @db.Date
  created_at                                 DateTime? @default(now()) @db.Timestamptz(6)
  expires_at                                 DateTime? @default(dbgenerated("(now() + '72:00:00'::interval)")) @db.Timestamptz(6)
  is_active                                  Boolean?  @default(true)
  profiles_engagements_receiver_idToprofiles profiles? @relation("engagements_receiver_idToprofiles", fields: [receiver_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  profiles_engagements_sender_idToprofiles   profiles? @relation("engagements_sender_idToprofiles", fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model profiles {
  id                                            String        @id
  email                                         String?
  full_name                                     String?
  avatar_url                                    String?
  stripe_customer_id                            String?       @unique
  is_pro                                        Boolean?      @default(false)
  is_artist                                     Boolean?      @default(false)
  subscription_status                           String?
  bio                                           String?
  location                                      String?
  social_links                                  Json?         @default("{\"spotify\": \"\", \"website\": \"\", \"instagram\": \"\"}")
  updated_at                                    DateTime?     @default(now()) @db.Timestamptz(6)
  vault_completed_at                            DateTime?     @db.Timestamptz(6)
  stripe_subscription_tier                      String?       @default("free")
  engagements_engagements_receiver_idToprofiles engagements[] @relation("engagements_receiver_idToprofiles")
  engagements_engagements_sender_idToprofiles   engagements[] @relation("engagements_sender_idToprofiles")
}

model OpenDate {
  id        String   @id @default(cuid())
  venueId   String
  eventDate DateTime
  isFilled  Boolean  @default(false)
  createdAt DateTime @default(now())
  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, eventDate])
}

model VenueAgreement {
  id              String   @id @default(cuid())
  venueId         String
  templateText    String?
  payoutStructure Json?
  uploadedFileUrl String?
  lastUpdated     DateTime @default(now()) @updatedAt
  venue           Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
}

enum MemberRole {
  OWNER
  MANAGER
  MEMBER
  GUEST
  ADMIN
}

enum GigStatus {
  DRAFT
  OFFER_SENT
  COUNTER_OFFER
  ACCEPTED
  REJECTED
  BOOKED
  COMPLETED
  CANCELLED
  ESCROW_HOLD
  CONFIRMED
  SUBMISSION
  REQUEST
  PENDING_APPROVAL
}

enum AvailabilityStatus {
  AVAILABLE
  BOOKED
  PAST
  CONFIRMED
}

enum EngagementType {
  SUBMISSION
  REQUEST
}

enum UserRole {
  BAND
  VENUE
  ADMIN
}

enum PayoutType {
  FABT_PAY
  CASH_DOS
}

enum DealType {
  GUARANTEE
  SPLIT
  NEGOTIABLE
}

enum PayoutStatus {
  NOT_APPLICABLE
  HELD_IN_ESCROW
  RELEASED_TO_BAND
  REFUNDED_TO_VENUE
  ADMIN
}

enum PaymentMethod {
  IN_PERSON
  PLATFORM
}

model VaultAsset {
  id        String   @id @default(cuid())
  ownerId   String
  assetType String   // 'i9', 'stage_plot', 'input_list', 'rider', 'agreement_template'
  fileUrl   String?
  rawText   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}
